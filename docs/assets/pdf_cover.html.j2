<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 210mm;
      height: 297mm;
      font-family: "Roboto", "Segoe UI", sans-serif;
      background: linear-gradient(160deg, #1c3fa8 0%, #44aaee 100%);
      color: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .cover-logo {
      width: 180px;
      margin-bottom: 2.5rem;
      filter: drop-shadow(0 4px 16px rgba(0,0,0,0.25));
    }

    .cover-title {
      font-size: 3.2rem;
      font-weight: 700;
      letter-spacing: -0.03em;
      text-align: center;
    }

    .cover-subtitle {
      font-size: 1.05rem;
      font-weight: 400;
      opacity: 0.85;
      text-align: center;
      max-width: 340px;
      margin-top: 1rem;
      line-height: 1.5;
    }

    .cover-divider {
      width: 60px;
      height: 3px;
      background: rgba(255,255,255,0.5);
      border-radius: 2px;
      margin: 2rem auto;
    }

    .cover-brand {
      font-size: 0.85rem;
      opacity: 0.65;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .cover-footer {
      position: absolute;
      bottom: 2.5rem;
      width: 100%;
      text-align: center;
      font-size: 0.75rem;
      opacity: 0.55;
      line-height: 1.7;
    }
  </style>
</head>
<body>

  <img class="cover-logo" src="{{ cover_logo }}" alt="{{ cover_title }}">

  <h1 class="cover-title">{{ cover_title }}</h1>

  <p class="cover-subtitle">{{ cover_subtitle }}</p>

  <div class="cover-divider"></div>

  <p class="cover-brand">by PythonWoods</p>

  <div class="cover-footer">
    {{ copyright }}<br>
    Build date: {{ config.extra.build_date }}
  </div>

</body>
</html>
