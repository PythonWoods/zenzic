#
# .zenzic.local.toml.example — Copy to .zenzic.local.toml and add to .gitignore.
# Local Override > Global Config (zenzic.toml). Additive merge for list fields.
# This file is a committed template. The actual .zenzic.local.toml is NEVER committed.
#
# Usage:
#   cp .zenzic.local.toml.example .zenzic.local.toml
#   echo ".zenzic.local.toml" >> .gitignore

[core]
# Override the documentation root when working in a non-standard local layout.
# docs_dir = "my/custom/path/to/docs"

[governance]
# Confidential terms that must not appear in public documentation (Z204 Privacy Gate).
# Patterns are matched case-insensitively. RE2 DFA syntax is supported.
# forbidden_patterns = [
#     "INTERNAL-CODENAME",
#     "staging.example.corp",
#     "acme-internal-api",
# ]

[build_context]
# Override engine or base_url for local experiments only.
# engine   = "docusaurus"
# base_url = "/"

[project_metadata]
# Local release name experiments — does not affect CI.
# release_name = "Basalt"

[governance]
# Raise suppression cap locally during large debt cleanup.
# suppression_cap           = 100
# suppression_cap_fail_hard = false

[i18n]
# Mirror global i18n shape for local experiments.
# enabled = true

[secrets]
# Store API tokens here — never in shared zenzic.toml.
# github_pat = "ghp_xxxxxxxxxxxxxxxxxxxx"

[debug]
# Granular diagnostics.
# log_level = "DEBUG"

[env]
# Local environment variables used by wrappers/scripts.
# ZENZIC_FORCE_COLOR = "true"
